# Google Gemini Vision — para analisar a foto do usuário
GEMINI_API_KEY=your_gemini_api_key_here

# Nano Banana 2 — para gerar a imagem final
NANO_BANANA_API_KEY=your_nano_banana_api_key_here
NANO_BANANA_API_URL=https://generativelanguage.googleapis.com

# Supabase — auth + storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Necessária para uploads server-side (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── STRIPE — pagamentos de créditos ──────────────────────────────────────────
# Chave secreta: stripe.com → Developers → API Keys → Secret key
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret: stripe.com → Developers → Webhooks → seu endpoint → Signing secret
# Em dev local: rode "stripe listen --forward-to localhost:3000/api/stripe/webhook"
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs dos 3 planos: stripe.com → Products → (cada produto) → Price ID
# Crie 3 produtos com pagamento único (one-time):
#   Básico — 50 créditos  → R$ 19,90
#   Pro    — 200 créditos → R$ 59,90
#   Business — 500 créditos → R$ 119,90
STRIPE_PRICE_BASICO=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
